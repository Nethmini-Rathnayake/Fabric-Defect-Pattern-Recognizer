# Kaggle (for kagglehub — alternatively use ~/.kaggle/kaggle.json)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Roboflow
ROBOFLOW_API_KEY=your_roboflow_api_key
# Model paths
MODEL_PATH=models/efficientnet/best.pt
CONFIDENCE_THRESHOLD=0.90

# RAG / LLM
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=fabric_defects
LLM_MODEL=llama3

# Experiment Tracking
MLFLOW_TRACKING_URI=http://localhost:5000
WANDB_API_KEY=your_wandb_key_here

# Camera / Video source (0 = webcam, or path to video file)
VIDEO_SOURCE=0

# Report output directory
REPORT_OUTPUT_DIR=reports/sinhala_pdf/output
